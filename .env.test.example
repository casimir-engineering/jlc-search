# =============================================================================
# Search the Chipyard — TEST environment overrides
#
# This file documents env vars used by docker-compose.test.yml.
# The test stack reads the main .env file via docker compose, then these
# values can be added/overridden at the bottom of .env or set via shell
# environment before running scripts/deploy-test.sh.
# =============================================================================

# --- Test database ---
# Separate database on the same Postgres container as prod.
# Created by scripts/init-test-db.sh. Falls back to constructed URL from
# POSTGRES_PASSWORD if not set explicitly.
DATABASE_URL_TEST=postgres://jlc:changeme@localhost:5432/jlc_test

# --- Analytics (PostHog disabled in test) ---
# Test containers explicitly set POSTHOG_KEY="" at container level in
# docker-compose.test.yml; the frontend test build also sets
# VITE_POSTHOG_KEY="" as a build arg so the bundle never calls PostHog.
# Do not override these here — they are already hardcoded in the test compose.
